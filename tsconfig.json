{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "rootDir": "src",
    "outDir": "scripts",
    "strict": true,
    "skipLibCheck": true,
    "noEmitOnError": true,
    "removeComments": false,
    "types": ["node"]
  },
  "include": ["src/**/*.mts"]
}
