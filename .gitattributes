# The scripts are authored in TypeScript (src/*.mts) and compiled to these .mjs
# files, which are committed so end users can run them with zero install. Mark them
# generated so GitHub's language stats credit the TypeScript source, not the build output.
scripts/*.mjs linguist-generated=true

# The demo report is built output (generated by build-report.mjs from a payload).
examples/demo-report.html linguist-generated=true
