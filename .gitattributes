# The scripts are authored in TypeScript (skills/slop-check/src/*.mts). Force the language
# so GitHub's detector never mis-labels the ESM TypeScript source as JavaScript.
*.mts linguist-language=TypeScript
*.mts linguist-detectable=true

# The .mts files are compiled to these .mjs files, which are committed so end users can
# run them with zero install. Mark them generated so GitHub's language stats credit the
# TypeScript source, not the build output.
skills/slop-check/scripts/*.mjs linguist-generated=true

# The demo report is built output (generated by build-report.mjs from a payload).
examples/demo-report.html linguist-generated=true
